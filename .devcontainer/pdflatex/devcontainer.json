{
	"name": "CoSAI Whitepaper Converter (pdflatex)",
	"dockerFile": "Dockerfile",

	"containerEnv": {
		"LATEX_ENGINE": "pdflatex"
	},

	"onCreateCommand": "./scripts/install-deps.sh",

	"customizations": {
		"vscode": {
			"extensions": [
				"charliermarsh.ruff",
				"ms-python.python"
			],
			"settings": {
				"python.testing.pytestEnabled": true,
				"python.testing.unittestEnabled": false,
				"python.testing.pytestArgs": ["tests"]
			}
		}
	},

	"remoteUser": "vscode"
}
