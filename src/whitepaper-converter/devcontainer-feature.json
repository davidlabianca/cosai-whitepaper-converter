{
  "id": "whitepaper-converter",
  "version": "0.4.0",
  "name": "CoSAI Whitepaper Converter",
  "description": "Dependencies for converting Markdown to PDF with CoSAI branding",
  "options": {
    "latexEngine": {
      "type": "string",
      "default": "tectonic",
      "proposals": ["tectonic", "pdflatex", "xelatex", "lualatex"],
      "description": "LaTeX engine to install"
    },
    "installPath": {
      "type": "string",
      "default": "/usr/local/lib/cosai-converter",
      "description": "Directory to install the converter tool (convert.py and assets)"
    },
    "skipChromium": {
      "type": "boolean",
      "default": false,
      "description": "Skip Chromium configuration"
    },
    "skipPython": {
      "type": "boolean",
      "default": false,
      "description": "Skip Python installation"
    },
    "skipNode": {
      "type": "boolean",
      "default": false,
      "description": "Skip Node.js installation"
    }
  },
  "containerEnv": {
    "COSAI_CONVERTER_INSTALLED": "true"
  },
  "installsAfter": [
    "ghcr.io/devcontainers/features/python",
    "ghcr.io/devcontainers/features/node"
  ]
}
