\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage{geometry}
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}
\RequirePackage{tikz}
\RequirePackage{hyperref}
\RequirePackage{tcolorbox}
\usepackage[defaultfam,tabular,lining]{montserrat} %% Option 'defaultfam'



% ============================================================================
% FONT CONFIGURATION - Easy customization section
% ============================================================================
%
% Font Weight Options (use with \fontseries{XX}\selectfont):
%   el = ExtraLight (lightest)
%   l  = Light
%   m  = Regular/Medium (normal weight)
%   sb = SemiBold
%   b  = Bold (heaviest)
%
% Font Size Commands:
%   \tiny, \scriptsize, \footnotesize, \small, \normalsize
%   \large, \Large, \LARGE, \huge, \Huge
%   Or use: \fontsize{size}{baselineskip}\selectfont (e.g., \fontsize{30}{36}\selectfont)
%
% ============================================================================

% --- Body Text Font Weight ---
% Default weight for all body text
\newcommand{\bodyFontWeight}{el}  % ExtraLight

% --- Bold Text Redefinition ---
% What weight to use when \textbf{} or **bold** is used in markdown
\newcommand{\boldFontWeight}{m}   % Regular (instead of actual bold)

% --- Cover Page Title ---
\newcommand{\coverTitleSize}{30}        % Font size in points
\newcommand{\coverTitleWeight}{el}      % Font weight (el, l, m, sb, b)

% --- Cover Page Author ---
\newcommand{\coverAuthorSize}{\Large}   % Size command
\newcommand{\coverAuthorWeight}{el}     % Font weight

% --- Section Headings (e.g., # Heading in markdown) ---
\newcommand{\sectionSize}{\Large}       % Size command
\newcommand{\sectionWeight}{l}         % Font weight (el, l, m, sb, b)

% --- Subsection Headings (e.g., ## Heading in markdown) ---
\newcommand{\subsectionSize}{\large}    % Size command
\newcommand{\subsectionWeight}{l}      % Font weight

% --- Subsubsection Headings (e.g., ### Heading in markdown) ---
\newcommand{\subsubsectionSize}{\normalsize}  % Size command
\newcommand{\subsubsectionWeight}{l}          % Font weight

% --- Figure Captions ---
% Note: Caption settings are applied directly below (caption package is picky about expansion)
% To change: modify the \captionsetup directly (lines 71-77)

% ============================================================================
% END OF FONT CONFIGURATION
% ============================================================================

\RequirePackage{caption}

% Define custom caption fonts with specific weights
\DeclareCaptionFont{mediumweight}{\fontseries{m}\selectfont}
\DeclareCaptionFont{extralight}{\fontseries{el}\selectfont}

% Caption configuration - modify these values directly:
\captionsetup[figure]{
    font={small,extralight},                 % Caption text: small size, extralight weight
    labelfont={mediumweight,color=cosaiDarkBlue}, % "Figure 1:" label: medium weight
    textfont=it,                             % Caption text style (italic)
    justification=centering,
    skip=10pt
}

% --- Figure Centering ---
% Make all figures centered by default
\makeatletter
\g@addto@macro\@floatboxreset\centering
\makeatother

% --- Color Palette ---
\definecolor{cosaiDarkBlue}{RGB}{17, 38, 64}
\definecolor{cosaiGreen}{RGB}{49, 97, 71}
\definecolor{cosaiWhite}{RGB}{255, 255, 255}

% --- Page Geometry ---
\geometry{letterpaper, margin=1in, bottom=1.2in, headheight=14pt}

% --- Font Application ---
% Using IBM Plex Sans as the default font family
\renewcommand{\familydefault}{\sfdefault}

%% only if the base font of the document is to be sans serif. Uncomment the two lines below in case of issues
% \usepackage[T1]{fontenc}
% \renewcommand*\oldstylenums[1]{{\fontfamily{Montserrat-TOsF}\selectfont #1}}


% Apply body font weight globally
\AtBeginDocument{%
  \fontseries{\bodyFontWeight}\selectfont
}

% Redefine bold commands to use configured weight instead of actual bold
\renewcommand{\bfseries}{\fontseries{\boldFontWeight}\selectfont}
\DeclareTextFontCommand{\textbf}{\fontseries{\boldFontWeight}\selectfont}

% --- Header & Footer ---
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyhead[L]{
    \begin{tikzpicture}[remember picture, overlay]
        \node[anchor=north west, xshift=0.5in, yshift=-0.3in] at (current page.north west) {
            \includegraphics[height=1.2cm]{cosai-logo.png}
        };
        \node[anchor=north east, inner sep=0pt] at (current page.north east) {
            \includegraphics[scale=0.25]{background.pdf}
        };
    \end{tikzpicture}
}
\makeatletter
\fancyfoot[L]{\footnotesize \textcolor{gray}{\@title}}
\makeatother
\fancyfoot[R]{\footnotesize \thepage}

% --- Custom Commands ---
\newcommand{\makeCoSAICover}[4]{
    \begin{titlepage}
        \begin{tikzpicture}[remember picture, overlay]
            \shade[top color=cosaiDarkBlue, bottom color=cosaiGreen] (current page.south west) rectangle (current page.north east);
            % Logo
            \node[anchor=north west, xshift=1in, yshift=-2.5cm] at (current page.north west) {
                \includegraphics[width=0.72\textwidth]{CoSAI(Light).pdf}
            };
            % Title
            \node[
                text=white,
                text width=1.0\textwidth,
                align=left,
                font=\fontseries{\coverTitleWeight}\fontsize{\coverTitleSize}{\coverTitleSize}\selectfont,
                yshift=3cm,
                xshift=0cm
                ] at (current page.center) {
                {\hyphenchar\font=-1 #1}
            };
            
            \draw[
                white,
                line width=5pt,
                cap=round
                ] ([yshift=-2cm, xshift=-4cm]current page.center) -- ++(0.9\textwidth, 0);
            % Author
            \node[
                text=white,
                text width=1.0\textwidth,
                align=left,
                font=\fontseries{\coverAuthorWeight}\coverAuthorSize,
                yshift=3cm,
                xshift=0cm,
                ] at (current page.south) {
                {\hyphenchar\font=-1 #2}
            };

            \node[
                text=white,
                text width=1.0\textwidth,
                align=right,
                font=\fontseries{\coverAuthorWeight}\coverAuthorSize,
                yshift=1cm,
                xshift=0cm,
                ] at (current page.south) {
                {\hyphenchar\font=-1 #3}
            };

            \node[
                text=gray,
                text width=1.0\textwidth,
                align=left,
                font=\fontseries{\coverAuthorWeight}\footnotesize,
                yshift=1cm,
                xshift=0cm,
                ] at (current page.south) {
                {\hyphenchar\font=-1 Version #4}
            };
        \end{tikzpicture}
    \end{titlepage}
}

\newcommand{\sectionIcon}[3]{
    \begin{tcolorbox}[colback=cosaiDarkBlue, colframe=cosaiDarkBlue, width=0.3\textwidth, height=3cm, sharp corners, center upper, valign=center]
        \leavevmode\color{white} #1 \\ \small #2
    \end{tcolorbox}
}

% --- Section Styling ---
\titleformat{\section}
  {\color{cosaiDarkBlue}\fontseries{\sectionWeight}\selectfont\sectionSize}
  {}
  {0pt}
  {}
  [{\color{cosaiGreen}\makebox[0.75\textwidth][l]{\rule{0.75\textwidth}{1pt}}}]

\titleformat{\subsection}
  {\color{cosaiDarkBlue}\fontseries{\subsectionWeight}\selectfont\subsectionSize}
  {}
  {0pt}
  {}

\titleformat{\subsubsection}
  {\color{cosaiDarkBlue}\fontseries{\subsubsectionWeight}\selectfont\subsubsectionSize}
  {}
  {0pt}
  {}