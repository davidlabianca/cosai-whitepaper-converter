\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cosai}[2024/05/20 CoSAI White Paper Template]

\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage{geometry}
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}
\RequirePackage{tikz}
\RequirePackage{hyperref}
\RequirePackage{tcolorbox}

% --- Color Palette ---
\definecolor{cosaiDarkBlue}{HTML}{002033}
\definecolor{cosaiGreen}{HTML}{6CC24A}
\definecolor{cosaiWhite}{HTML}{FFFFFF}

% --- Page Geometry ---
\geometry{letterpaper, margin=1in, bottom=1.2in, headheight=14pt}

% --- Fonts ---
% Note: Using standard sans-serif. For exact match, use LuaLaTeX/XeLaTeX with Montserrat.
\renewcommand{\familydefault}{\sfdefault}

% --- Header & Footer ---
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyhead[L]{
    \begin{tikzpicture}[remember picture, overlay]
        \node[anchor=north west, xshift=0.5in, yshift=-0.3in] at (current page.north west) {
            \includegraphics[height=1.2cm]{cosai-logo.png}
        };
    \end{tikzpicture}
}
\fancyfoot[L]{\footnotesize \textcolor{gray}{\@title}}
\fancyfoot[R]{\footnotesize \thepage}

% --- Custom Commands ---
\newcommand{\makeCoSAICover}[2]{
    \begin{titlepage}
        \begin{tikzpicture}[remember picture, overlay]
            \fill[cosaiDarkBlue] (current page.south west) rectangle (current page.north east);
        \end{tikzpicture}
        \centering
        \vspace*{2cm}
        {\includegraphics[width=0.8\textwidth]{cosai-logo.png}\par}
        \vfill
        {\color{cosaiWhite}\Huge\bfseries #1\par}
        \vspace{1cm}
        {\color{cosaiWhite}\Large #2\par}
        \vspace*{2cm}
    \end{titlepage}
}

\newcommand{\sectionIcon}[3]{
    \begin{tcolorbox}[colback=cosaiDarkBlue, colframe=cosaiDarkBlue, width=0.3\textwidth, height=3cm, sharp corners, center upper, valign=center]
        \leavevmode\color{white} #1 \\ \small #2
    \end{tcolorbox}
}

% --- Section Styling ---
\titleformat{\section}{\color{cosaiDarkBlue}\normalfont\Large\bfseries}{}{0pt}{}